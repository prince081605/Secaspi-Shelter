APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
FRONTEND_URL=http://localhost:5173

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
# Upload storage disk. Use "public" for local dev (files in storage/app/public,
# served via the storage symlink at APP_URL/storage — run `php artisan storage:link`).
# Production sets this to "s3" so uploads persist on S3-compatible storage (R2).
# Uploaded image URLs are now generated by the backend via Storage::url(), so this
# disk's resolved URL must be reachable by the browser (set APP_URL accordingly in dev).
FILESYSTEM_DISK=public
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Bearer-token lifetime in minutes (default 14 days). Used by config/sanctum.php.
SANCTUM_TOKEN_EXPIRATION=20160

# File storage. Local disk is the dev default; production sets FILESYSTEM_DISK=s3
# (above) and points these at S3-compatible storage (e.g. Cloudflare R2) so uploads
# survive container redeploys. For R2: region is "auto", AWS_URL is the public
# bucket URL (pub-xxxxx.r2.dev or a custom domain), AWS_ENDPOINT is the account
# S3 endpoint (https://<ACCOUNT_ID>.r2.cloudflarestorage.com).
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=auto
AWS_BUCKET=
AWS_URL=
AWS_ENDPOINT=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
