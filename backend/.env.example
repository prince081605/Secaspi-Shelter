APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
FRONTEND_URL=http://localhost:5173

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
# Upload storage disk. Use "public" for local dev (files in storage/app/public,
# served via the storage symlink at APP_URL/storage — run `php artisan storage:link`).
# Production sets this to "s3" so uploads persist on S3-compatible storage (R2).
# Uploaded image URLs are now generated by the backend via Storage::url(), so this
# disk's resolved URL must be reachable by the browser (set APP_URL accordingly in dev).
FILESYSTEM_DISK=public
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Gmail SMTP. Generate an App Password at https://myaccount.google.com/apppasswords
# (requires 2-Step Verification on the Google account). Paste the 16 chars with no spaces.
# For local dev you can keep MAIL_MAILER=log instead — the reset token is shown on screen.
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-account@gmail.com
MAIL_PASSWORD=
MAIL_FROM_ADDRESS="your-account@gmail.com"
MAIL_FROM_NAME="${APP_NAME}"

# Bearer-token lifetime in minutes (default 14 days). Used by config/sanctum.php.
SANCTUM_TOKEN_EXPIRATION=20160

# File storage. Local disk is the dev default; production sets FILESYSTEM_DISK=s3
# (above) and points these at S3-compatible storage (e.g. Cloudflare R2) so uploads
# survive container redeploys. For R2: region is "auto", AWS_URL is the public
# bucket URL (pub-xxxxx.r2.dev or a custom domain), AWS_ENDPOINT is the account
# S3 endpoint (https://<ACCOUNT_ID>.r2.cloudflarestorage.com).
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=auto
AWS_BUCKET=
AWS_URL=
AWS_ENDPOINT=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Database backups (spatie/laravel-backup). Nightly DB dumps are uploaded to the disk
# named by BACKUP_DISK (default "s3" → the R2/S3 disk configured above via AWS_*). In
# local dev you can set BACKUP_DISK=local to drop dumps in storage/app/private instead.
# Failure notifications are emailed to BACKUP_NOTIFY_EMAIL over the MAIL_* settings.
# Run a manual backup anytime with `php artisan backup:run`; list them with `backup:list`.
BACKUP_DISK=s3
BACKUP_NOTIFY_EMAIL=your-account@gmail.com
# Shared secret for the HTTP backup trigger (POST /api/internal/backup), sent in the
# X-Backup-Token header by the GitHub Actions cron (.github/workflows/backup.yml). This is
# how nightly backups run on Render Free, where the sleeping web service can't keep the
# in-app scheduler alive. Generate a long random value; leave empty to disable the endpoint.
BACKUP_TRIGGER_TOKEN=

# AI Shelter Assistant (optional). Leave OPENAI_API_KEY blank to run the assistant in free
# FAQ-only mode — it still answers common questions with zero API cost. Add a key to enable
# live AI answers. Admin toggles it on/off and sets the daily per-visitor cap in Settings.
# A cheap model is the default; the API base URL is configurable for OpenAI-compatible providers.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MAX_TOKENS=320
# Optional: only set if the DB dump binary (pg_dump / mysqldump) isn't on PATH. Production
# doesn't need this. Local Windows MySQL example: "C:\Program Files\MySQL\MySQL Server 8.0\bin".
DB_DUMP_BINARY_PATH=

VITE_APP_NAME="${APP_NAME}"
